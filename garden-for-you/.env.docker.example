NODE_ENV=production
PORT=3000

# Browser-facing Medusa URL (public backend domain in production)
NEXT_PUBLIC_MEDUSA_URL=http://localhost:9000

# Server-side Medusa URL inside the Docker network
MEDUSA_BACKEND_URL=http://backend:9000

# Public (client-inlined) — must also be passed as build args in docker-compose
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_replace_me
NEXT_PUBLIC_REGION_ID=reg_replace_me
NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_CONTENT_TABLE_URL=https://opensheet.elk.sh/replace_me/

# Server-only — must match backend REVALIDATE_SECRET
REVALIDATE_SECRET=replace_with_strong_secret

# Cloudinary (client upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
